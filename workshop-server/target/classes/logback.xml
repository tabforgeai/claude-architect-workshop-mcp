<?xml version="1.0" encoding="UTF-8"?>
<!--
  CRITICAL: ALL output goes to STDERR.
  STDOUT is reserved exclusively for MCP protocol JSON-RPC messages.

  Claude Desktop reads MCP tool responses from STDOUT.
  A single stray log line on STDOUT corrupts the JSON framing
  and causes Claude Desktop to lose the connection.

  CERTIFICATION NOTE — Tool Design & MCP Integration (18% of exam):
  The STDOUT/STDERR separation is a required constraint of the MCP stdio
  transport. Any MCP server running over stdio must respect this contract.
-->
<configuration>

  <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
    <!-- Target STDERR — not STDOUT -->
    <target>System.err</target>
    <encoder>
      <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>

  <!-- Sub-agent calls — log at DEBUG to see token counts and API timings -->
  <logger name="ai.tabforge.workshop.agents" level="DEBUG"/>

  <!-- Orchestration loop — INFO shows the lifecycle stages -->
  <logger name="ai.tabforge.workshop.orchestrator" level="INFO"/>

  <!-- MCP tool calls — INFO shows incoming tool invocations -->
  <logger name="ai.tabforge.workshop.server" level="INFO"/>
  <logger name="ai.tabforge.workshop.tools" level="INFO"/>

  <!-- HTTP client (Anthropic SDK) — WARN in production, DEBUG for dev -->
  <logger name="okhttp3" level="WARN"/>
  <logger name="com.anthropic" level="WARN"/>

  <!-- MCP SDK internals — WARN to avoid noise -->
  <logger name="io.modelcontextprotocol" level="WARN"/>

  <root level="INFO">
    <appender-ref ref="STDERR"/>
  </root>

</configuration>
